# LLM Provider - use "gemini" for FREE (recommended), "groq" for FREE, or "openai" for paid
LLM_PROVIDER=gemini

# Google Gemini API Key (FREE - get one at https://aistudio.google.com/app/apikey)
# Sign up at Google AI Studio, create an API key, and paste it below
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API Key (FREE - alternative free option at https://console.groq.com/)
GROQ_API_KEY=your-groq-api-key-here

# OpenAI API Key (PAID - only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# Tavily API Key for web search (optional, not used in current implementation)
TAVILY_API_KEY=your-tavily-api-key-here

# Model configuration
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini/gemini-2.0-flash-exp

# Logging level
LOG_LEVEL=INFO

# Max research iterations for feedback loop
MAX_RESEARCH_ITERATIONS=3
