# LLM Provider - use "groq" for FREE & FAST (recommended)
# NOTE: Web UI supports AUTOMATIC FALLBACK - if one provider hits rate limits,
# it will automatically switch to backup providers. Set multiple API keys for best reliability!
LLM_PROVIDER=groq

# Groq API Key (FREE - FASTEST option, recommended - https://console.groq.com/)
# Fallback chain: llama-3.1-8b-instant → llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key-here

# Kimi/Moonshot API Key (Large context window - https://platform.moonshot.cn/)
# Used as fallback after Groq, great for complex research with lots of context
KIMI_API_KEY=your-kimi-api-key-here

# Google Gemini API Key (FREE backup - https://aistudio.google.com/app/apikey)
# Used as fallback if Groq and Kimi hit rate limits
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (PAID backup - only needed as final fallback)
OPENAI_API_KEY=your-openai-api-key-here



# Model configuration (Primary models - fallbacks are automatic)

GROQ_MODEL=llama-3.1-8b-instant


# Kimi model options:
# - moonshot-v1-8k (8K context, fastest)
# - moonshot-v1-32k (32K context, balanced)
# - moonshot-v1-128k (128K context, for very long documents)

# Logging level
LOG_LEVEL=INFO

# Max research iterations for feedback loop (1=fast, 2=balanced, 3=thorough)
MAX_RESEARCH_ITERATIONS=1
