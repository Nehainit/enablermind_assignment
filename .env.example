# LLM Provider - use "gemini" for FREE (recommended), "groq" for FREE, or "openai" for paid
# NOTE: Web UI now supports AUTOMATIC FALLBACK - if one provider hits rate limits,
# it will automatically switch to backup providers. Set multiple API keys for best reliability!
LLM_PROVIDER=groq

# Groq API Key (FREE - FASTEST option, recommended for web UI - https://console.groq.com/)
# Fallback chain: llama-3.1-8b-instant → mixtral-8x7b-32768 → llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key-here

# Google Gemini API Key (FREE backup - get one at https://aistudio.google.com/app/apikey)
# Used as fallback if Groq hits rate limits
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (PAID backup - only needed as final fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Tavily API Key for web search (optional, not used in current implementation)
TAVILY_API_KEY=your-tavily-api-key-here

# Model configuration (Primary models - fallbacks are automatic)
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-1.5-flash

# Logging level
LOG_LEVEL=INFO

# Max research iterations for feedback loop
MAX_RESEARCH_ITERATIONS=3
